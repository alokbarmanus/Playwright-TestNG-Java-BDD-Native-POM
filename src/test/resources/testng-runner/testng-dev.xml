<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Playwright BDD TestNG Suite - DEV" parallel="tests" thread-count="4" verbose="1">

    <listeners>
        <listener class-name="com.automation.utils.CustomReporter"/>
        <listener class-name="com.automation.listeners.ExtentReportListener"/>
    </listeners>

    <test name="DEV_Execution">
        <parameter name="txt.scenario.file.ext" value=".feature"/>
        <parameter name="step.provider.pkg" value="com.automation.stepdefinitions"/>
        <parameter name="env.resources" value="src/test/resources/environments/dev"/>

        <parameter name="cucumber.filter.tags" value="@dashboardpage08"/>

        <classes>
            <class name="com.automation.runners.TestRunner"/>
        </classes>
    </test>
</suite>
